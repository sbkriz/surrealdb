# Add the platform name to the output directory.
build --experimental_platform_in_output_dir

# Use the blake3 digest function which is significantly faster than sha256.
startup --digest_function=blake3

# Enable the use of the platform specific config files.
common --enable_platform_specific_config=true

# Bazel Clippy configuration.
build:clippy --aspects=@rules_rust//rust:defs.bzl%rust_clippy_aspect
build:clippy --output_groups=+clippy_checks
build --@rules_rust//:clippy.toml=//:.clippy.toml

# Bazel Rustfmt configuration.
build:rustfmt --aspects=@rules_rust//rust:defs.bzl%rustfmt_aspect
build:rustfmt --output_groups=+rustfmt_checks
build --@rules_rust//:rustfmt.toml=//:.rustfmt.toml

# Formatting configuration.
build:fmt --config=rustfmt

# Linting configuration.
build:lint --//tools/settings:lint=true
build:lint --config=clippy

# ---- Sandbox & execution performance ----
build --reuse_sandbox_directories
build:linux --spawn_strategy=sandboxed,worker,local
build:macos --spawn_strategy=processwrapper-sandbox,worker,local

common --repository_cache=~/.cache/bazel-repo

# ---- Language test persistent workers ----
# Keep surrealql-test processes alive across test invocations so that
# bootstrapped Datastore instances are reused instead of recreated per test.
# Multiplex workers handle concurrent requests internally with a datastore
# pool sized to available_parallelism(), so only 2 processes are needed
# (one per backend transition / binary variant).
build --strategy=SurrealQLTest=worker,local
build --worker_max_instances=SurrealQLTest=4

# TiKV tests share a single playground cluster on port 2379, so they
# must be serialised: one singleplex worker, one request at a time.
build --strategy=SurrealQLTestTikV=worker,local
build --worker_max_instances=SurrealQLTestTikV=1

# The test phase runs trivial shell wrappers that just read a result file.
# Allow high parallelism for these since they have negligible resource cost.
test:lang --local_test_jobs=HOST_CPUS*2

# ---- BuildBuddy remote cache ----
# Activate with --config=remote-cache (requires API key via .bazelrc.user).
build:remote-cache --bes_results_url=https://surrealdb.buildbuddy.io/invocation/
build:remote-cache --bes_backend=grpcs://surrealdb.buildbuddy.io
common:remote-cache --remote_cache=grpcs://surrealdb.buildbuddy.io
common:remote-cache --noremote_upload_local_results # Uploads logs & artifacts without writing to cache
common:remote-cache --remote_timeout=10m
build:remote-cache --remote_download_toplevel
common:remote-cache --remote_cache_compression=true


build:ci --config=remote-cache
build:ci --remote_upload_local_results
build:ci --build_metadata=ROLE=CI
build:ci --jobs=HOST_CPUS*1.5


# ---- CI test profile shortcuts ----
# These set build settings for a specific test configuration.
# Useful for one-off builds: bazel build --config=cli-integration //:surreal

build:cli-integration --//tools/settings:storage_engine=mem --//tools/settings:feature_http=true --//tools/settings:feature_scripting=true --//tools/settings:feature_jwks=true --//tools/settings:feature_cli=true
build:http-integration --//tools/settings:storage_engine=mem --//tools/settings:feature_jwks=true
build:ws-integration --//tools/settings:storage_engine=mem
build:graphql-integration --//tools/settings:storage_engine=mem --//tools/settings:feature_graphql=true
build:workspace-test --//tools/settings:storage_engine=mem --//tools/settings:feature_http=true --//tools/settings:feature_scripting=true --//tools/settings:feature_jwks=true
build:kvs-mem --//tools/settings:storage_engine=mem
build:kvs-rocksdb --//tools/settings:storage_engine=rocksdb
build:kvs-surrealkv --//tools/settings:storage_engine=surrealkv
build:kvs-tikv --//tools/settings:storage_engine=tikv

# Import user-local settings (API keys, personal overrides).
try-import %workspace%/.bazelrc.user
