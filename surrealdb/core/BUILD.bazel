rust_library(
    name = "core",
    crate_features = [
        "kv-mem",
        "graphql",
    ],
    crate_name = "surrealdb_core",
    proc_macro_deps = all_crate_deps(proc_macro = True),
    rustc_flags = [
        "--cfg",
        "storage",
    ],
    test_compile_data = [
        "Cargo.toml",
        "test.surql",
    ],
    visibility = ["//visibility:public"],
    deps = _EXTERNAL_DEPS + [
        "//surrealdb/types",
    ],
)
