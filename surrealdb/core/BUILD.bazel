load("@crates_io//:defs.bzl", "all_crate_deps")
load("//tools/rust:defs.bzl", "rust_library")

# surrealdb-core has many optional deps gated by features. all_crate_deps()
# returns ALL resolved deps (including heavy native ones like rocksdb/tikv)
# regardless of enabled features. We list deps explicitly for correctness.
#
# Non-optional deps + deps enabled by kv-mem and graphql features.

